            "id": "cebb7f86de4acbed89e0484ce472b5920cba43fd71ce4f1085a782ed7782e2c7",
            "rendered": "#!/usr/bin/env bash\n\nset -e\n\ncurl -s -o /etc/yum.repos.d/jenkins.repo https://pkg.jenkins.io/redhat-stable/jenkins.repo\nrpm --import https://pkg.jenkins.io/redhat-stable/jenkins.io-2023.key\ndnf upgrade\ndnf install -y \\\n    unzip \\\n    git \\\n    java-21-amazon-corretto \\\n    jenkins\ndnf clean all\nrm -rf /var/cache/dnf/*\n\nsystemctl daemon-reload\nsystemctl enable jenkins\n\nJENKINS_USER=jenkins\nJENKINS_HOME=\"/var/lib/$JENKINS_USER\" \n\necho JENKINS_ADMIN_ID=admin \u003e\u003e /etc/environment\necho JENKINS_ADMIN_PASSWORD=seppel1 \u003e\u003e /etc/environment\n\nexport JENKINS_ADMIN_ID=admin\nexport JENKINS_ADMIN_PASSWORD=seppel1\n\nmkdir $JENKINS_HOME/.ssh\ntouch $JENKINS_HOME/.ssh/known_hosts\nchmod 700 $JENKINS_HOME/.ssh\necho \"-----BEGIN OPENSSH PRIVATE KEY-----\nb3BlbnNzaC1rZXktdjEAAAAABG5vbmUAAAAEbm9uZQAAAAAAAAABAAACFwAAAAdzc2gtcn\nNhAAAAAwEAAQAAAgEA+SGnRiYQUSCIl19fNLTseYnQDmYV+Z5c7WTzgIhFGsxATJIAWcbm\ni2yva5qkK/DPbVyy9UxPIfZC9hOw067I3fWgphob8pvtu7TcqlNRt2l5yHKMAie1Zy4qM2\nb+RNBhrEkD2PpdgcmI1uwNey3qpbN1gtRd9L6w6DKvmKvKKtajfj1SiZJchhAFUi6uO+PU\nYhpHtmte6nY8YgxX2x9Mozd202+85BxI7SqBHXouhModaBvnXOeeJEJrUCV/xn+MrULFZG\n6kcaEcySt15uPZfqOo/60OuXVeZlX2kJNMdMIj3ABH1WghbUaCh1eYNZ7Ox7OVel6M+6Aq\nRvxgkpCkROgNVk36YyPYzHQO9pCytY+PeAt5W7yvqqPz70sQBH6sIZsLC5OSY6NhfasO6A\nZiqbhVfst3WvXt6txQN+mXFycN8vDpMarAIrbToZbV6pdRu+nagQAZE3MezMroXCDun+ly\nuN/gsLKuWdXm6oF/O5T1xH6qR2CxPvjaeCXcCP3vpiD2m7P5rDoZ3MNfRLBzbH3xiOWOj3\nTh89KPmxHy3dQ4L9pVpDTA03D9BKDdA4Eh9pU/dm7I92zhCgy0HgaWECLD/OKnndzmi4iy\nTZGB4k8znBs8nUX5GRD4b4gp2yi7LRA2mphuhaiLi3Y1BC/mSUZ2XeYQ6k8yI5jnsc7F5G\nEAAAdQogbe8KIG3vAAAAAHc3NoLXJzYQAAAgEA+SGnRiYQUSCIl19fNLTseYnQDmYV+Z5c\n7WTzgIhFGsxATJIAWcbmi2yva5qkK/DPbVyy9UxPIfZC9hOw067I3fWgphob8pvtu7Tcql\nNRt2l5yHKMAie1Zy4qM2b+RNBhrEkD2PpdgcmI1uwNey3qpbN1gtRd9L6w6DKvmKvKKtaj\nfj1SiZJchhAFUi6uO+PUYhpHtmte6nY8YgxX2x9Mozd202+85BxI7SqBHXouhModaBvnXO\neeJEJrUCV/xn+MrULFZG6kcaEcySt15uPZfqOo/60OuXVeZlX2kJNMdMIj3ABH1WghbUaC\nh1eYNZ7Ox7OVel6M+6AqRvxgk